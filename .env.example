# ============================================================
# RENU — 環境變數範本
# 用法：複製這個檔成 .env.local，把值填進去（.env.local 已被 gitignore，不會上傳）
# ============================================================

# ---- 網站正式網址（SEO 用，等業主 domain 來了再改）----
# 例：https://washshoes.vercel.app 或 https://www.你的網域.com.tw
NEXT_PUBLIC_SITE_URL=

# ============================================================
# Firebase — 公開設定（來自 Firebase 主控台 → 專案設定 → Web 應用程式）
# 這 6 個是「公開」值，放在前端沒問題
# ============================================================
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ============================================================
# Firebase Admin — 機密！（來自 專案設定 → 服務帳戶 → 產生新的私密金鑰 的 JSON）
# 絕對不要 commit、不要貼到公開地方。只放在 .env.local 與 Vercel 環境變數。
# ------------------------------------------------------------
# 從下載的 JSON 取這三個欄位：
#   "project_id"   -> FIREBASE_PROJECT_ID
#   "client_email" -> FIREBASE_CLIENT_EMAIL
#   "private_key"  -> FIREBASE_PRIVATE_KEY
# 注意 private_key 很長且含換行，請整段用雙引號包起來，保留裡面的 \n，例如：
#   FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
# ============================================================
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
